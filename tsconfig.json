{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "allowJs": false,
    "noEmit": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["bun"],
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "include": ["server", "src", "tests", "public", "types.d.ts"]
}
