{
  "name": "peerpay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch run server/index.ts",
    "start": "bun run server/index.ts",
    "build:bin": "bun build --compile --target=bun-linux-x64 --production --outfile=dist/peerpay ./server/index.ts",
    "publish": "bun run scripts/publish.ts",
    "build": "bun build --target=bun --production --root . --outdir=dist ./server/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "antd:lint": "antd lint src/client --format json"
  },
  "dependencies": {
    "@ant-design/icons": "latest",
    "antd": "latest",
    "qrcode": "^1.5.4",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@ant-design/cli": "latest",
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest"
  }
}
